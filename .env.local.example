APP_NAME=api-starter-local
APP_ENV=dev
APP_PORT=8080

DB_HOST=localhost
DB_PORT=5432
DB_NAME=api_starter
DB_USER=postgres
DB_PASSWORD=postgres

JWT_ACCESS_SECRET=replace-with-local-access-secret-minimum-32-chars
JWT_REFRESH_SECRET=replace-with-local-refresh-secret-minimum-32-chars
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30

OAUTH_GOOGLE_ENABLED=false
OAUTH_GITHUB_ENABLED=false
HMAC_ENABLED=false
FIELD_ENCRYPTION_ENABLED=false

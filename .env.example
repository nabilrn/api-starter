APP_NAME=api-starter
APP_ENV=dev
APP_PORT=8080

DB_HOST=localhost
DB_PORT=5432
DB_NAME=api_starter
DB_USER=postgres
DB_PASSWORD=postgres

JWT_ACCESS_SECRET=change-me-access-secret-minimum-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-minimum-32-chars
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30

OAUTH_GOOGLE_ENABLED=false
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GITHUB_ENABLED=false
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=

HMAC_ENABLED=false
HMAC_SECRET=
HMAC_MAX_SKEW_SECONDS=300
HMAC_PROTECTED_PATHS=/api/v1/webhooks,/api/v1/internal

FIELD_ENCRYPTION_ENABLED=false
# Base64-encoded 32-byte key. Generate with: openssl rand -base64 32
FIELD_ENCRYPTION_KEY=
